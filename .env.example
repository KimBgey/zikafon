# ─────────────────────────────────────────────────────────────────────────────
#  Zikafon — Variables d'environnement (modèle)
#  Copie ce fichier en .env.local et remplis tes propres clés.
#  Ne commite JAMAIS .env.local — il est dans .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Gemini API — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Firebase — https://console.firebase.google.com → Paramètres du projet → Tes apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
